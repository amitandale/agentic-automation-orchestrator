# =============================================================================
# Agentic Automation Orchestrator — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it is git-ignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Postgres — used by Paperclip)
# -----------------------------------------------------------------------------
DB_PASS=change_me_to_a_strong_password

# -----------------------------------------------------------------------------
# LLM API (OpenRouter — routes to Claude and GPT models for the Hermes-Agent)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# Social Account Credentials (used by OpenClaw browser sessions)
# -----------------------------------------------------------------------------
OPENCLAW_REDDIT_USER=
OPENCLAW_REDDIT_PASS=
OPENCLAW_TWITTER_USER=
OPENCLAW_TWITTER_PASS=
OPENCLAW_DISCORD_TOKEN=
OPENCLAW_FACEBOOK_USER=
OPENCLAW_FACEBOOK_PASS=

# -----------------------------------------------------------------------------
# WhatsApp (approval notifications routed here)
# -----------------------------------------------------------------------------
OPENCLAW_WHATSAPP_NUMBER=+1XXXXXXXXXX

# -----------------------------------------------------------------------------
# Reader App (link generation & tracking)
# -----------------------------------------------------------------------------
READER_APP_URL=https://your-reader-app.com
READER_AGENT_API_KEY=

# -----------------------------------------------------------------------------
# Budget Caps (USD per day — enforced atomically by Paperclip)
# -----------------------------------------------------------------------------
BUDGET_OPENCLAW_DAILY=1.50
BUDGET_HERMES_DAILY=4.00

# -----------------------------------------------------------------------------
# Staging / E2E Mode
# Set to "true" to run browser flows in dry-run mode (no actual submissions)
# -----------------------------------------------------------------------------
DRY_RUN=false

# -----------------------------------------------------------------------------
# Backup Configuration
# -----------------------------------------------------------------------------
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Approval Timeout (hours) — pending approvals archived after this duration
# -----------------------------------------------------------------------------
APPROVAL_TIMEOUT_HOURS=24

# -----------------------------------------------------------------------------
# Dual-Funnel Configuration
# -----------------------------------------------------------------------------
DEFAULT_FUNNEL=secular
SUPPORTED_LANGUAGES=es,en
